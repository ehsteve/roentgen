msgstr "**transition** : Nom de la transition en notation Siegbahn"

#: ../../../roentgen/data/README.rst:49
msgid "**intensity**: Relative intensity of the line"
msgstr "**intensity** : Intensité relative de la raie"

#: ../../../roentgen/data/README.rst:50
msgid "**width**: Line width in eV"
msgstr "**width** : Largeur de la raie en eV"

